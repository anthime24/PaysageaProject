# Variables d'environnement — Backend Node.js
# Copier ce fichier en .env et remplir les valeurs

# ─── API Keys ─────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_places_api_key_here
BFL_API_KEY=your_black_forest_labs_api_key_here

# ─── Config serveur ───────────────────────────────────────────────────────────
PORT=3001

# ─── Mode mock (true = pas d'appel BFL réel, utile en dev) ───────────────────
MOCK_BFL=false

# ─── Python path (optionnel, défaut: "python") ────────────────────────────────
# PYTHON_PATH=python3
